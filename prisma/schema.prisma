generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
}

model User {
  id             String         @id @default(uuid())
  matricula      String         @unique
  name           String
  password       String
  avatarUrl      String?
  role           Role           @default(OPERATOR)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  assetHistories AssetHistory[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Product {
  id         String   @id @default(uuid())
  name       String
  brand      String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  assets     Asset[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

enum AssetStatus {
  DISPONIVEL
  EM_USO
  EM_MANUTENCAO
  DEFEITO
  DESCARTADO
}

model Asset {
  id          String         @id @default(uuid())
  patrimonio  String         @unique
  status      AssetStatus    @default(DISPONIVEL)
  location    String
  responsible String?
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  history     AssetHistory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
}

model AssetHistory {
  id          String       @id @default(uuid())
  assetId     String
  asset       Asset        @relation(fields: [assetId], references: [id])
  oldStatus   AssetStatus?
  newStatus   AssetStatus
  oldLocation String?
  newLocation String?
  observation String?      @db.VarChar(500)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
}
