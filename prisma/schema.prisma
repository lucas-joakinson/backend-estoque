generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String          @id @default(uuid())
  name        String          @unique
  users       User[]
  permissions RolePermission?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
}

model RolePermission {
  id                 String   @id @default(uuid())
  roleId             String   @unique
  role               Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  canManageUsers     Boolean  @default(false)
  canManageProducts  Boolean  @default(false)
  canManageCategories Boolean  @default(false)
  canManageAssets    Boolean  @default(false)
  canDeleteItems     Boolean  @default(false)
  canViewReports     Boolean  @default(false)
  updatedAt          DateTime @default(now()) @updatedAt
}

model User {
  id               String           @id @default(uuid())
  matricula        String           @unique
  name             String
  password         String
  avatarUrl        String?
  roleId           String
  role             Role             @relation(fields: [roleId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt
  assetHistories   AssetHistory[]
  headsetHistories HeadsetHistory[]
  computerHistories ComputerHistory[]
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Product {
  id         String   @id @default(uuid())
  name       String
  brand      String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  assets     Asset[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

enum AssetStatus {
  DISPONIVEL
  EM_USO
  EM_MANUTENCAO
  DEFEITO
  DESCARTADO
}

model Asset {
  id          String         @id @default(uuid())
  patrimonio  String         @unique
  status      AssetStatus    @default(DISPONIVEL)
  location    String
  responsible String?
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  history     AssetHistory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
}

model AssetHistory {
  id          String       @id @default(uuid())
  assetId     String
  asset       Asset        @relation(fields: [assetId], references: [id])
  oldStatus   AssetStatus?
  newStatus   AssetStatus
  oldLocation String?
  newLocation String?
  observation String?      @db.VarChar(500)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
}

model Headset {
  id          Int              @id @default(autoincrement())
  matricula   String
  lacre       String           @unique
  marca       String
  numeroSerie String?          @unique
  status      String
  observacoes String?
  history     HeadsetHistory[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model HeadsetHistory {
  id          Int      @id @default(autoincrement())
  headsetId   Int
  headset     Headset  @relation(fields: [headsetId], references: [id])
  oldStatus   String?
  newStatus   String
  oldLocation String?
  newLocation String?
  observation String?  @db.VarChar(500)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Computador {
  id          Int               @id @default(autoincrement())
  patrimonio  String            @unique
  hostname    String
  status      String
  localizacao String
  history     ComputerHistory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ComputerHistory {
  id           Int        @id @default(autoincrement())
  computadorId Int
  computador   Computador @relation(fields: [computadorId], references: [id])
  oldStatus    String?
  newStatus    String
  oldLocation  String?
  newLocation  String?
  observation  String?    @db.VarChar(500)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
}
