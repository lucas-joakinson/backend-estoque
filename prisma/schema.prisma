generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String          @id @default(uuid())
  name        String          @unique
  users       User[]
  permissions RolePermission?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
}

model RolePermission {
  id                 String   @id @default(uuid())
  roleId             String   @unique
  role               Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  canManageUsers     Boolean  @default(false)
  canManageProducts  Boolean  @default(false)
  canManageCategories Boolean  @default(false)
  canManageAssets    Boolean  @default(false)
  canDeleteItems     Boolean  @default(false)
  canViewReports     Boolean  @default(false)
  // --- NOVAS PERMISSÕES ---
  canManageComputers Boolean  @default(false)
  canDeleteComputers Boolean  @default(false)
  canManageHeadsets  Boolean  @default(false)
  canDeleteHeadsets  Boolean  @default(false)
  canExportData      Boolean  @default(false)
  canManageNotifications Boolean @default(false)
  updatedAt          DateTime @default(now()) @updatedAt
}

model NotificationSettings {
  id                       String   @id @default("global")
  min_headsets_disponiveis  Int      @default(10)
  max_headsets_defeito      Int      @default(5)
  updatedAt                DateTime @default(now()) @updatedAt
}

model User {
  id               String           @id @default(uuid())
  matricula        String           @unique
  name             String
  password         String
  avatarUrl        String?
  lastActivityClear DateTime?
  roleId           String
  role             Role             @relation(fields: [roleId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt
  assetHistories   AssetHistory[]
  headsetHistories HeadsetHistory[]
  computerHistories ComputerHistory[]
  categoryHistories CategoryHistory[]
  productHistories  ProductHistory[]
  userTargetHistories UserHistory[] @relation("UserTarget")
  userActionHistories UserHistory[] @relation("UserPerformer")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  history   CategoryHistory[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model CategoryHistory {
  id          String   @id @default(uuid())
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  itemName    String
  action      String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Product {
  id         String   @id @default(uuid())
  name       String
  brand      String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  assets     Asset[]
  history    ProductHistory[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model ProductHistory {
  id          String   @id @default(uuid())
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  itemName    String
  action      String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model UserHistory {
  id          String   @id @default(uuid())
  targetUserId String?
  targetUser  User?    @relation("UserTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  itemName    String
  action      String
  userId      String
  user        User     @relation("UserPerformer", fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

enum AssetStatus {
  DISPONIVEL
  EM_USO
  EM_MANUTENCAO
  DEFEITO
  DESCARTADO
}

model Asset {
  id          String         @id @default(uuid())
  patrimonio  String         @unique
  status      AssetStatus    @default(DISPONIVEL)
  location    String
  responsible String?
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  history     AssetHistory[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt
}

model AssetHistory {
  id          String       @id @default(uuid())
  assetId     String?
  asset       Asset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  itemName    String?
  oldStatus   AssetStatus?
  newStatus   AssetStatus
  oldLocation String?
  newLocation String?
  observation String?      @db.VarChar(500)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
}

enum HeadsetStatus {
  EM_USO
  RESERVA
  TROCA_PENDENTE
  EM_MANUTENCAO
  DEFEITO
  DISPONIVEL
}

model Headset {
  id          Int              @id @default(autoincrement())
  matricula   String?          @unique
  lacre       String           @unique
  marca       String
  numeroSerie String?          @unique
  status      HeadsetStatus    @default(DISPONIVEL)
  observacoes String?
  history     HeadsetHistory[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model HeadsetHistory {
  id          Int            @id @default(autoincrement())
  headsetId   Int?
  headset     Headset?       @relation(fields: [headsetId], references: [id], onDelete: SetNull)
  itemName    String?
  oldStatus   HeadsetStatus?
  newStatus   HeadsetStatus
  oldLocation String?
  newLocation String?
  observation String?        @db.VarChar(500)
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  }

  model Computador {
  id          Int               @id @default(autoincrement())
  patrimonio  String            @unique
  hostname    String
  status      String
  localizacao String
  observacoes String?
  history     ComputerHistory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ComputerHistory {
  id           Int        @id @default(autoincrement())
  computadorId Int?
  computador   Computador? @relation(fields: [computadorId], references: [id], onDelete: SetNull)
  itemName     String?
  oldStatus    String?
  newStatus    String
  oldLocation  String?
  newLocation  String?
  observation  String?    @db.VarChar(500)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
}
